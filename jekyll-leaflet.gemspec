Gem::Specification.new do |s|
  s.name        = 'jekyll-leaflet'
  s.version     = '0.0.3'
  s.date        = '2026-04-22'
  s.summary     = "Embed Leaflet.js maps in Jekyll pages"
  s.description = "Embed Leaflet.js maps in Jekyll pages"
  s.authors     = ["Ben Mordue"]
  s.email       = 'benmordue@gmail.com'
  s.files       = ["lib/jekyll-leaflet.rb"]
  s.homepage    =
    'https://rubygems.org/gems/jekyll-leaflet'
  s.license       = 'MIT'

  s.add_runtime_dependency 'jekyll', '>= 3.5', '< 5.0'
end
